rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // OTP collection — public write/read/delete for unauthenticated login flow
    match /otps/{otpId} {
      allow create: if true;
      allow read, delete: if true;
    }

    // Merchant top-level documents are publicly readable (tracking page, store info)
    // Subcollections (orders, pagers, wallet, etc.) remain auth-gated
    match /merchants/{merchantId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
