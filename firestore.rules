rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // OTP collection — public write/read/delete for unauthenticated login flow
    match /otps/{otpId} {
      allow create: if true;
      allow read, delete: if true;
    }

    match /merchants/{merchantId} {
      // Top-level merchant document: public read (tracking page shows store name/logo/config)
      // Write: requires Firebase Auth (merchant must be signed in)
      allow read: if true;
      allow write: if request.auth != null;

      // whatsappOrders: customers submit orders and track them without authentication
      match /whatsappOrders/{orderId} {
        allow read, create: if true;
        allow update, delete: if request.auth != null;
      }

      // pagers: tracking page reads pager status without authentication
      match /pagers/{pagerId} {
        allow read: if true;
        allow write: if request.auth != null;
      }

      // All other subcollections (wallet, settings, coupons, etc.): merchant-only
      match /{subcollection=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
